# Copy this file to backend/.env and fill in real values before running.

FLASK_SECRET=change-me-32-chars-minimum-random
FLASK_DEBUG=true
HOST=0.0.0.0
PORT=5000

# Must match the frontend origin (or * for dev)
ALLOWED_ORIGINS=http://localhost:5173

JWT_SECRET=change-me-32-chars-minimum-random
JWT_EXPIRY_HOURS=24

# BB84 simulation parameters
BB84_NUM_QUBITS=256
BB84_NOISE=true
BB84_DEPOLAR=0.02
KEY_REFRESH_EVERY=5
